generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String            @unique
  passwordHash    String?
  role            UserRole          @default(USER)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  profile         Profile?
  submissions     IntakeSubmission[]
  generations     Generation[]
  payments        Payment[]
  reports         Report[]
  adminNotes      AdminNote[]       @relation("AdminAuthor")
  notesAboutUser  AdminNote[]       @relation("AdminSubject")
  accounts        Account[]
  sessions        Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  linkedinUrl     String?
  currentHeadline String?
  targetRole      String?
  industry        String?
  seniority       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IntakeSubmission {
  id                 String      @id @default(cuid())
  userId             String
  goal               String
  targetRole         String
  currentHeadline    String?
  linkedinUrl        String?
  proudAchievements  String
  audience           String
  niche              String
  tone               String
  avoidWords         String?
  status             String      @default("SUBMITTED")
  createdAt          DateTime    @default(now())
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations        Generation[]
}

model PromptVersion {
  id          String      @id @default(cuid())
  code        String      @unique
  version     String
  template    String
  schema      Json
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  generations Generation[]
}

model Generation {
  id                String            @id @default(cuid())
  userId            String
  intakeSubmissionId String
  promptVersionId   String
  status            GenerationStatus  @default(QUEUED)
  model             String
  retryCount        Int               @default(0)
  rawOutput         Json?
  errorMessage      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  intakeSubmission  IntakeSubmission  @relation(fields: [intakeSubmissionId], references: [id], onDelete: Cascade)
  promptVersion     PromptVersion     @relation(fields: [promptVersionId], references: [id])
  report            Report?
  logs              GenerationLog[]
}

model Report {
  id                    String     @id @default(cuid())
  userId                String
  generationId          String     @unique
  diagnosisSummary      String
  positioningAngle      String
  headline              String
  about                 String
  experienceRewrites    Json
  starterPosts          Json
  improvementPriorities Json
  createdAt             DateTime   @default(now())
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation            Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  provider       String
  providerRef    String?
  amountCents    Int
  currency       String        @default("BRL")
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  paidAt         DateTime?
  metadata       Json?
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminNote {
  id          String   @id @default(cuid())
  userId      String
  adminId     String
  note        String
  createdAt   DateTime @default(now())
  subjectUser User     @relation("AdminSubject", fields: [userId], references: [id], onDelete: Cascade)
  adminUser   User     @relation("AdminAuthor", fields: [adminId], references: [id], onDelete: Cascade)
}

model GenerationLog {
  id           String     @id @default(cuid())
  generationId String
  step         String
  status       String
  message      String
  createdAt    DateTime   @default(now())
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
}
